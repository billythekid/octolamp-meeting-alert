# Copy this file to .env and edit values as needed.
# Everything is optional; unset keys fall back to defaults in octolamp_meeting_alert.py.

# --- Required in practice ---

# WLED device's mDNS hostname or LAN IP.
WLED_HOST=wled.local

# Comma-separated substrings that identify you inside ATTENDEE fields on your
# calendar events. Both the mailto URI and the CN (display name) are checked,
# so bare email fragments AND display names work. Matching is case-insensitive.
# Per-item quotes are stripped, so use quotes when a value contains a comma or
# you just want it visually clear.
#
# Examples (pick whichever fragments actually appear in your calendar):
#   SELF_EMAIL_HINTS=firstname.lastname,firstnamelastname
#   SELF_EMAIL_HINTS=jane.doe,"Jane Doe","J. Doe"
SELF_EMAIL_HINTS=firstname.lastname,"Firstname Lastname",handle

# --- Timing (minutes, unless noted) ---

#POLL_SECONDS=30
#WARN_MINUTES=5
#IMMINENT_MINUTES=1
#END_WARN_MINUTES=5
#ICS_LOOKAHEAD_MINUTES=60
#ICS_LOOKBACK_MINUTES=240

# --- Colours (RGB, 0-255, comma-separated) ---

# Pre-meeting warn (rendered with EFFECT_ALERT).
#WARN_COLOUR=255,140,0
# Imminent + in-meeting (solid).
#BUSY_COLOUR=255,0,0
# Last END_WARN_MINUTES of a meeting (solid).
#ENDING_COLOUR=0,200,40

# --- WLED effect IDs ---

# Solid colour.
#EFFECT_SOLID=0
# Two-colour effect used for pre-meeting warn. 12 = Fade in WLED's stock list.
#EFFECT_ALERT=12
